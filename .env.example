# Telegram Bot (get token from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your personal chat ID — ONLY used to authorize admin commands (/status, /force_scan)
# Users don't need this. To find yours: message @userinfobot on Telegram
TELEGRAM_ADMIN_CHAT_ID=your_personal_chat_id

# EarnKaro
EARNKARO_API_KEY=your_earnkaro_api_key

# Scanner Config
SCAN_INTERVAL_MINUTES=5
IBJA_FETCH_RETRIES=3

# Database
DB_PATH=./data/gold-tracker.db

# Logging
LOG_LEVEL=info

# Proxy for Myntra (optional — needed if VPS IP gets 403'd)
# Supports: http, https, socks5 proxies
# Examples:
#   MYNTRA_PROXY=http://user:pass@proxy-host:port
#   MYNTRA_PROXY=socks5://user:pass@proxy-host:port
# Leave empty to connect directly (works from residential IPs)
MYNTRA_PROXY=

# Cloudflare Worker proxy for Myntra (RECOMMENDED for VPS/cloud deployment)
# Bypasses datacenter IP blocking by routing through CF edge network.
# Free tier: 100K requests/day. Setup: see cf-worker/README.md
CF_WORKER_URL=
CF_WORKER_SECRET=
